##############################################################
# .env.example — SOILL Public RAG Chatbot
##############################################################

# Copy to .env at the repository root and fill in values. Never commit .env.
# Python 3.11–3.13 supported (Chainlit is not supported on 3.14).

# =============================================================================
# 1. PostgreSQL (Render Postgres + pgvector)
# =============================================================================
# Render web service: use the internal DATABASE_URL from the linked database.
# Local admin (ingest, reports, db init): use the external connection string
# from the Render Postgres dashboard.
#
# After creating the database, install the pgvector extension, then run once: uv run soill-db-init

# Add the remote database connection details below in the format shown
DATABASE_URL=postgresql://user:password@host:5432/soill


# =============================================================================
# 2. Mistral API
# =============================================================================
MISTRAL_API_KEY=

MISTRAL_EMBED_MODEL=mistral-embed
MISTRAL_CHAT_MODEL=mistral-small-latest


# =============================================================================
# 3. RAG retrieval
# =============================================================================
RAG_TOP_K=8

RAG_MMR_ENABLED=true
RAG_MMR_LAMBDA=0.58
RAG_MMR_FETCH_MULT=3
RAG_MMR_FETCH_CAP=40


# =============================================================================
# 4. Conversation logging and multi-turn chat
# =============================================================================
LOG_CONVERSATIONS=true

# Also store client_ip and user_agent (GDPR: disclose in your privacy notice).
LOG_CLIENT_METADATA=true

CHAT_HISTORY_ENABLED=true
CHAT_HISTORY_TURNS=3
CHAT_HISTORY_MAX_ANSWER_CHARS=1500
CHAT_HISTORY_EXPAND_RETRIEVAL=true
CHAT_HISTORY_RETRIEVAL_MAX_CHARS=2000


# =============================================================================
# 5. Local admin (ingestion and OCR pre-processing)
# =============================================================================
# Optional override; default is <repo>/SourceDocuments
# SOURCE_DOCUMENTS=/path/to/SourceDocuments

# OCR batch folders default to <repo>/PDFPreProcessing (see documents/OCR_PDF_PreProcessingWorkflow.md)
# PDF_PREPROCESSING_ROOT=/path/to/PDFPreProcessing
# OCR_LANGUAGE=eng
# OCR_FORCE=false
